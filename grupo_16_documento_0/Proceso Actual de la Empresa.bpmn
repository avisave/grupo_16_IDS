    <userTask id="Id_77eae4d2-6628-40da-a52e-2cdb70ad60c2" name="Registrar la venta ">
      <documentation>&lt;p style="text-align:left;text-indent:0pt;margin:0pt 0pt 0pt 0pt;"&gt;&lt;span style="color:#000000;background-color:transparent;font-family:Calibri;font-size:11pt;font-weight:normal;font-style:normal;"&gt;Se ingresan los datos a un Excel de forma manual: Fecha, Cliente, Valor total, Monto devengado (anticipo) y saldo pendiente. Para el control mensual&lt;/span&gt;&lt;/p&gt;</documentation>
      <extensionElements>
        <bizagi:BizagiExtensions xmlns:bizagi="http://www.bizagi.com/bpmn20">
          <bizagi:BizagiProperties>
            <bizagi:BizagiProperty name="bgColor" value="#ECEFFF" />
            <bizagi:BizagiProperty name="borderColor" value="#03689A" />
            <bizagi:BizagiProperty name="textColor" value="#000000" />
            <bizagi:BizagiProperty name="textBackgroundColor" value="Transparent" />
            <bizagi:BizagiProperty name="textDirection" value="Horizontal" />
            <bizagi:BizagiProperty name="runtimeProperties" value="{&quot;cost&quot;:0,&quot;priority&quot;:0,&quot;notifyOnMobile&quot;:false,&quot;isSingleton&quot;:false,&quot;isConditional&quot;:false}" />
          </bizagi:BizagiProperties>
        </bizagi:BizagiExtensions>
      </extensionElements>
      <incoming>Id_5f0ff425-360e-4947-91cb-fb19cd48653d</incoming>
      <outgoing>Id_f589bd05-3205-4a02-a5d7-f67e32eb75fe</outgoing>
