    <userTask id="Id_a115d80e-a8de-446b-8653-71baa7f07284" name="Sacar copia Nota de venta y subir al Drive">
      <documentation>&lt;p style="text-align:left;text-indent:0pt;margin:0pt 0pt 0pt 0pt;"&gt;&lt;span style="color:#000000;background-color:transparent;font-family:Calibri;font-size:11pt;font-weight:normal;font-style:normal;"&gt;Se digitaliza el papel que lleg&amp;oacute; de terreno mediante una foto o esc&amp;aacute;ner y se sube al drive como respaldo digital.&lt;/span&gt;&lt;/p&gt;</documentation>
