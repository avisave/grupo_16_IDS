    <userTask id="Id_a08b08a5-6f6b-4264-9bc7-34b00ccd58d2" name="Pagar el saldo restante">
      <documentation>&lt;p style="text-align:left;text-indent:0pt;margin:0pt 0pt 0pt 0pt;"&gt;&lt;span style="color:#000000;background-color:transparent;font-family:Calibri;font-size:11pt;font-weight:normal;font-style:normal;"&gt;El cliente realiza la transferencia, pago por transbank o abono del 50% restante&lt;/span&gt;&lt;/p&gt;</documentation>
