        <mxCell id="tdYsdXLD13EspsR5QW8r-72" parent="tdYsdXLD13EspsR5QW8r-67" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=10;align=left;verticalAlign=top;spacing=8;" value="&lt;div&gt;&lt;span style=&quot;white-space: nowrap; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- Prod: 2x Instancias c5.2xlarge (16 vCPU, 32GB RAM total)&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- Test: 1x Instancia t3.medium (2 vCPU, 4GB RAM)&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- Disco: 200 GB SSD por instancia (Alta velocidad IOPS)&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: nowrap; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- OS: Red Hat Enterprise Linux (RHEL)&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- Entorno Backend: Python (API RESTful)&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- Rendimiento de red: Hasta 10 Gbps (VPC)&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- Dirección IP pública estática IPv4 dedicada&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- Puertos abiertos: 80 y 443 (HTTPS)&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- VPN Proton Essentials (Conexión cifrada)&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- Firewall y reglas de Security Groups&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- Certificado SSL/TLS (Let&#39;s Encrypt o similar)&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- Compresión Gzip/Brotli habilitada&lt;br&gt;- Cache: max-age=1 año para assets con hash&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- CDN opcional para assets estáticos&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- Build: React 18 + Vite 5 + TailwindCSS 3&lt;/font&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
