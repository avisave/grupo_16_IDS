: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Cámara: 12 MP Recomendado&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-align: center;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;-Almacenamiento local de JWT (sessionStorage vía navegador o AsyncStorage)&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-align: center;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;-Tener habilitado JavaScript y cookies en el navegador&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-align: center;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;-Conexión VPN habilitada si se requiere acceso restringido&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
