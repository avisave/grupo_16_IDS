          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam style strictuml\ntitle CU-46: Editando parámetros de fabricación de Terminaciones (Excepción 1)\n\nactor \&quot;Administrador / Gerente / JOP\&quot; as Actor\nparticipant \&quot;V_EditarTerminacionesMetalmecanica\&quot; as V\n\nActor -&gt; V : 1. Borra el valor de un campo estético obligatorio y guarda los cambios\nactivate V\n\n\nV --&gt; Actor : 2. Muestra un mensaje de advertencia en pantalla y previene el guardado\ndeactivate V\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="fjH6-aq_U2aFYfVj_jjP-16">
