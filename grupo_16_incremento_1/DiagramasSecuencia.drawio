          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam style strictuml\ntitle CU-50: Definiendo el nivel de urgencia de la tarea (Excepción 1)\n\nactor \&quot;Administrador / Gerente / JOP\&quot; as Actor\nparticipant \&quot;V_Tareas\&quot; as V\nparticipant \&quot;C_Router\&quot; as R\nparticipant \&quot;C_tareaController\&quot; as C\n\nActor -&gt; V : 1. Omite selección de la alternativa y confirma la operación\nactivate V\n\nV -&gt; R : 2. Solicitar asignación de jerarquía de urgencia\nactivate R\n\nR -&gt; C : 3. Validar presencia de la opción de urgencia seleccionada\nactivate C\n\nC --&gt; R : 4. Denegar actualización por campo vacío\ndeactivate C\n\nR --&gt; V : 5. Enviar orden de bloqueo de guardado\ndeactivate R\n\nV --&gt; Actor : 6. Bloquear el guardado del nivel de urgencia\ndeactivate V\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="fjH6-aq_U2aFYfVj_jjP-18">
