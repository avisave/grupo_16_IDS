    <mxGraphModel dx="2408" dy="2541" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam style strictuml\ntitle CU-01: Iniciando sesión en la plataforma con credenciales válidas (Excepción 2)\n\nactor \&quot;Administrador/Gerente/Técnico/JOP/Secretaria\&quot; as Actor\nparticipant \&quot;V_Login\&quot; as V\nparticipant \&quot;C_Router\&quot; as R\nparticipant \&quot;C_loginController\&quot; as C\nparticipant \&quot;inventario.usuario\&quot; as T\n\nActor -&gt; V : 1. Ingresa su RUT y contraseña y presiona ingresar\nactivate V\n\nV -&gt; R : 2. Envia credenciales de acceso\nactivate R\n\nR -&gt; C : 3. Solicita autenticación del usuario\nactivate C\n\nC -&gt; T : 4. Consulta datos del usuario por RUT\nactivate T\nT --&gt; C : 5. Retorna información con estado de cuenta inactivo\ndeactivate T\n\nC --&gt; R : 6. Rechaza autenticación por cuenta deshabilitada\ndeactivate C\n\nR --&gt; V : 7. Responde con restricción de acceso\ndeactivate R\n\nV --&gt; Actor : 8. Bloquea visualmente el avance y notifica la inactividad\ndeactivate V\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="AWpr7Szba-3f4W8RiGoS-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
